# App Configuration
APP_URL=http://localhost:3005
PORT=3005
HOST=127.0.0.1

# Spotify API Credentials
# Get them from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_ARTIST_ID=your_spotify_artist_id_here

# YouTube API Credentials
# Get them from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# Bandsintown API Credentials
# Get them from https://artists.bandsintown.com/support/api
BANDSINTOWN_APP_ID=your_bandsintown_app_id_here

# Paystack API Credentials
# Get them from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
VITE_PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
